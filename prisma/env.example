NODE_ENV=development
PORT=8080

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/medvault_cloud?schema=public"

# Auth
JWT_SECRET=""
# Used to reversibly encrypt hospital HMAC secrets at rest (AES-256-GCM key material).
# Generate with: openssl rand -hex 32
SECRET_ENCRYPTION_KEY=""

HMAC_CLOCK_SKEW_SECONDS=300

# WhatsApp Cloud API (Meta) — leave blank in local dev, the AI agent route will no-op
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_ACCESS_TOKEN=""

# Claude API — powers the WhatsApp AI agent
ANTHROPIC_API_KEY=""

# Daily.co — telemedicine video rooms (same provider your offline HMS already uses)
DAILY_API_KEY=""
DAILY_SUBDOMAIN=""

# Expo push notifications (optional access token, not required for basic sends)
EXPO_ACCESS_TOKEN=""

# Object storage (Backblaze B2, S3-compatible) — KYC documents/selfies.
# Endpoint format: https://s3.<region>.backblazeb2.com
B2_ENDPOINT=""
B2_REGION=""
B2_BUCKET=""
B2_KEY_ID=""
B2_APPLICATION_KEY=""

# Transactional email — Namecheap Private Email SMTP
SMTP_HOST="mail.med-vault.com"
SMTP_PORT=465
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="MedVAULT <notifications@med-vault.com>"

# Public URL doctors/lab staff use to log in — included in welcome emails
WEB_APP_URL="https://cloud.med-vault.com"
