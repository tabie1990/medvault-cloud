generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum HospitalStatus {
  active
  suspended
  disabled
}

enum InstallationStatus {
  active
  suspended
  revoked
}

enum EventDirection {
  hospital_to_cloud
  cloud_to_hospital
}

enum SyncStatus {
  pending
  queued
  processed
  failed
  ignored
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
  completed
  rejected
}

enum ProviderType {
  hospital
  independent
  lab
  pharmacy
}

enum VerificationStatus {
  pending
  verified
  rejected
  suspended
}

enum PaymentStatus {
  unpaid
  pending
  paid
}

enum PaymentSplitStatus {
  pending
  completed
  failed
}

enum LabServiceType {
  home_visit
  on_site
  both
}

enum LabOrderStatus {
  requested
  scheduled
  sample_collected
  in_progress
  completed
  cancelled
}

enum TelemedicineStatus {
  scheduled
  ongoing
  completed
  cancelled
  no_show
}

enum NotificationChannel {
  whatsapp
  push
  sms
  email
}

enum NotificationStatus {
  pending
  sent
  failed
}

enum OtpPurpose {
  patient_login
  doctor_login
  password_reset
}

// ── Core: hospitals, installations, identity, sync (Phase 1-6) ─────────────

model Hospital {
  id            String   @id @default(uuid()) @db.Uuid
  hospitalId    String   @unique
  hospitalCode  String   @unique @db.VarChar(3)
  name          String
  country       String   @default("Cameroon")
  region        String?
  city          String?
  latitude      Float?
  longitude     Float?
  status        HospitalStatus @default(active)
  hospitalMomoNumber  String? // fallback payout target when the doctor has none set
  hospitalMomoNetwork String?
  // Chosen over per-doctor consultation fees: one flat fee per hospital,
  // covering the whole in-person visit regardless of which roster doctor
  // is selected. Paid to hospitalMomoNumber above via the exact same
  // splitPayout() path teleconsults already use — that function already
  // falls back to the hospital's own MoMo whenever an appointment has no
  // doctor attached, so this needed no changes to the payout logic at all.
  flatBookingFee      Decimal?
  // Hospital-level, not per-doctor like teleconsult's own
  // teleconsultSlotMinutes — one slot length applies to every roster
  // doctor at this hospital.
  appointmentSlotMinutes Int @default(15)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  installations HospitalInstallation[]
  patientMaps   PatientIdentityMap[]
  appointments  Appointment[]
  labProviders  LabProvider[]
  labOrders     LabOrder[]
  doctorRoster  HospitalDoctorRoster[]
  services      HospitalService[]
}

// A hospital's doctors, as manually entered by a MedVAULT admin —
// deliberately NOT the same as the Doctor model, which implies cloud
// login, KYC, and teleconsult capability. A hospital-employed doctor
// seen by patients/the WhatsApp agent for an in-person booking has none
// of that; this is purely a display roster. Chosen over an HMS→cloud
// push sync for the pilot: real HMS-side risk avoided, at the honest
// cost of needing manual updates if a hospital's roster changes.
model HospitalDoctorRoster {
  id           String   @id @default(uuid()) @db.Uuid
  hospitalId   String
  fullName     String
  specialty    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  hospital     Hospital @relation(fields: [hospitalId], references: [hospitalId])
  workingHours HospitalDoctorWorkingHours[]
  appointments Appointment[]
}

// Same shape as LabWorkingHours, deliberately — one day/time-range model
// used consistently across labs and hospital-roster doctors, not two
// near-identical ones.
model HospitalDoctorWorkingHours {
  id        String   @id @default(uuid()) @db.Uuid
  rosterId  String   @db.Uuid
  dayOfWeek Int      // 0=Sunday .. 6=Saturday
  startTime String   // "08:00"
  endTime   String   // "14:00"
  createdAt DateTime @default(now())
  roster    HospitalDoctorRoster @relation(fields: [rosterId], references: [id])
}

// What a hospital offers, e.g. "Emergency Care," "Maternity," "General
// Consultation" — informational, shown to patients browsing hospitals.
model HospitalService {
  id         String   @id @default(uuid()) @db.Uuid
  hospitalId String
  name       String
  createdAt  DateTime @default(now())
  hospital   Hospital @relation(fields: [hospitalId], references: [hospitalId])
}

model HospitalInstallation {
  id                   String   @id @default(uuid()) @db.Uuid
  hospitalId           String
  installationId       String   @unique @db.Uuid
  deviceLabel          String?
  licenseKeyHash       String
  // Reversibly encrypted (AES-256-GCM, see services/crypto.service.ts) so the
  // server can compute the expected HMAC without ever asking the client to
  // resend the raw secret on every request.
  hmacSecretEncrypted  String
  status               InstallationStatus @default(active)
  lastSeenAt           DateTime?
  createdAt            DateTime @default(now())
  hospital             Hospital @relation(fields: [hospitalId], references: [hospitalId])
  patientMaps          PatientIdentityMap[]
}

model GlobalPatient {
  id                 String   @id @default(uuid()) @db.Uuid
  globalPatientId    String   @unique
  primaryPhone       String?
  email              String?
  fullName           String?
  dob                DateTime?
  sex                String?
  country            String   @default("Cameroon")
  identityConfidence Decimal  @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  identityMaps       PatientIdentityMap[]
  appointments       Appointment[]
  labOrders          LabOrder[]
  telemedicineSessions TelemedicineSession[]
  whatsAppContacts   WhatsAppContact[]
  prescriptions      Prescription[]
}

model PatientIdentityMap {
  id                  String   @id @default(uuid()) @db.Uuid
  globalPatientId     String
  hospitalId          String
  installationId      String   @db.Uuid
  hospitalPatientUuid String   @db.Uuid
  localPatientId      String
  hospitalCode        String   @db.VarChar(3)
  matchStatus         String   @default("confirmed")
  createdAt           DateTime @default(now())
  globalPatient       GlobalPatient @relation(fields: [globalPatientId], references: [globalPatientId])
  hospital            Hospital @relation(fields: [hospitalId], references: [hospitalId])
  installation        HospitalInstallation @relation(fields: [installationId], references: [installationId])

  @@unique([hospitalId, localPatientId])
  @@unique([hospitalId, hospitalPatientUuid])
}

model SyncEvent {
  id              String @id @default(uuid()) @db.Uuid
  hospitalId      String
  installationId  String @db.Uuid
  eventId         String @db.Uuid
  eventType       String
  entityType      String
  entityId        String
  localPatientId  String?
  globalPatientId String?
  payload         Json
  direction       EventDirection
  status          SyncStatus @default(pending)
  errorMessage    String?
  createdAt       DateTime @default(now())
  queuedAt        DateTime?
  processedAt     DateTime?

  @@unique([hospitalId, installationId, eventId])
  @@index([hospitalId, status])
  @@index([globalPatientId])
}

model Appointment {
  id                String @id @default(uuid()) @db.Uuid
  appointmentRef    String @unique
  globalPatientId   String?
  hospitalId        String?
  doctorId          String? @db.Uuid
  // Which hospital-roster doctor was selected for an in-person booking —
  // separate from doctorId above, which only ever points at a cloud
  // Doctor (teleconsult-capable, has a login). A roster doctor has
  // neither, so this needed its own nullable FK rather than reusing
  // doctorId for both.
  hospitalDoctorRosterId String? @db.Uuid
  appointmentType   String
  requestedDate     DateTime?
  requestedTime     String?
  status            AppointmentStatus @default(pending)
  source            String
  channel           String?
  notes             String?
  payload           Json?
  // Payment — mirrors the HMS's own teleconsult payment fields exactly,
  // since that implementation is already tested end-to-end with a real
  // phone. Patient pays the full amount via Campay; splitting it between
  // MedVAULT's platform fee and the doctor/hospital happens separately
  // (see PaymentSplit) once this is 'paid'.
  paymentStatus     PaymentStatus @default(unpaid)
  paymentReference  String? // Campay's transaction reference
  paymentAmount     Decimal?
  paymentPhone      String? // the payer's MoMo number, not necessarily the patient's own
  syncedToHospitalAt DateTime? // NULL = not yet fanned out to the hospital's sync queue.
                               // Dedicated column, not a JSON payload marker — a JSON-path
                               // "equals: true" filter silently excludes rows where the key
                               // doesn't exist at all (NULL comparisons in SQL are neither
                               // true nor false, so WHERE treats them as no-match), which is
                               // the opposite of what "not yet synced" needs. Found via a real
                               // pilot appointment that never reached the hospital.
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  globalPatient     GlobalPatient? @relation(fields: [globalPatientId], references: [globalPatientId])
  hospital          Hospital? @relation(fields: [hospitalId], references: [hospitalId])
  doctor            Doctor? @relation(fields: [doctorId], references: [id])
  hospitalDoctorRoster HospitalDoctorRoster? @relation(fields: [hospitalDoctorRosterId], references: [id])
  telemedicineSession TelemedicineSession?
  paymentSplits     PaymentSplit[]
  prescriptions     Prescription[]
  referredLabOrders LabOrder[]
}

model Doctor {
  id                  String @id @default(uuid()) @db.Uuid
  doctorRef           String @unique
  fullName            String
  phone               String? @unique
  email               String? @unique
  passwordHash        String?
  mustChangePassword  Boolean @default(false)
  specialty           String?
  licenseNumber       String?
  verificationStatus  VerificationStatus @default(pending)
  providerType        ProviderType @default(independent)
  // KYC — manual document review, no automated verification exists for
  // Cameroon's Ordre National des Médecins register. See ARCHITECTURE.md.
  nationalIdDocumentKey     String? // object storage key, not a public URL
  medicalLicenseDocumentKey String?
  selfieKey                 String?
  kycSubmittedAt            DateTime?
  kycReviewedAt             DateTime?
  kycReviewedBy             String?  // AdminUser.id
  kycRejectionReason        String?
  // Where their share of a split payout actually gets sent — see PaymentSplit.
  momoNumber          String?
  momoNetwork         String? // 'MTN' | 'Orange'
  teleconsultFee      Decimal? @default(0)
  // Teleconsult scheduling — deliberately independent of any hospital's
  // own physical booking system (the HMS already handles that separately
  // for in-person visits at a fixed 25-minute default). A doctor's
  // willingness to take remote teleconsults doesn't map to their physical
  // hours, so this is modeled as its own thing, not synced from anywhere.
  teleconsultSlotMinutes Int @default(15) // configurable per doctor, not platform-fixed
  consultationTypes      Json? @default("[]") // e.g. ["General Consultation","Follow-up","Pediatric"]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  appointments        Appointment[]
  labProviders        LabProvider[]
  labOrdersReferred   LabOrder[]
  telemedicineSessions TelemedicineSession[]
  prescriptions       Prescription[]
  availability        DoctorAvailability[]
}

// A doctor's recurring weekly teleconsult availability — e.g. "Monday
// 08:00-12:00 and 14:00-17:00". Slots are generated dynamically from this
// (see availability.service.ts) rather than pre-materialized as rows, so
// there's nothing to keep in sync if a doctor changes their hours.
model DoctorAvailability {
  id         String   @id @default(uuid()) @db.Uuid
  doctorId   String   @db.Uuid
  dayOfWeek  Int      // 0=Sunday .. 6=Saturday
  startTime  String   // "08:00", 24-hour, plain wall-clock (single-timezone deployment)
  endTime    String   // "12:00"
  createdAt  DateTime @default(now())
  doctor     Doctor   @relation(fields: [doctorId], references: [id])
}

model LabStaff {
  id                 String   @id @default(uuid()) @db.Uuid
  labProviderId      String   @db.Uuid
  fullName           String
  email              String?  @unique
  phone              String?  @unique
  passwordHash       String
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  labProvider        LabProvider @relation(fields: [labProviderId], references: [id])
}

model AdminUser {
  id                 String   @id @default(uuid()) @db.Uuid
  email              String   @unique
  fullName           String
  passwordHash       String
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
}

model AuditLog {
  id          String @id @default(uuid()) @db.Uuid
  actorType   String?
  actorId     String?
  action      String
  entityType  String?
  entityId    String?
  ipAddress   String?
  metadata    Json?
  createdAt   DateTime @default(now())
}

// ── New: lab marketplace, telemedicine, notifications, auth support ────────

model LabProvider {
  id                 String   @id @default(uuid()) @db.Uuid
  providerRef        String   @unique
  name               String
  ownerDoctorId      String?  @db.Uuid
  hospitalId         String?
  serviceType        LabServiceType @default(on_site)
  homeServiceFee     Decimal? @default(0)
  // Where a lab order payout goes — falls back to the owning doctor's
  // momo if unset, same fallback pattern as Hospital's for appointments.
  momoNumber         String?
  momoNetwork        String?
  city               String?
  region             String?
  verificationStatus VerificationStatus @default(pending)
  // KYC — same manual-review reasoning as Doctor above.
  businessRegistrationNumber     String?
  businessRegistrationDocumentKey String?
  labAccreditationDocumentKey     String?
  ownerIdDocumentKey              String?
  kycSubmittedAt                  DateTime?
  kycReviewedAt                   DateTime?
  kycReviewedBy                   String? // AdminUser.id
  kycRejectionReason              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  ownerDoctor        Doctor?   @relation(fields: [ownerDoctorId], references: [id])
  hospital           Hospital? @relation(fields: [hospitalId], references: [hospitalId])
  services           LabService[]
  orders             LabOrder[]
  staff              LabStaff[]
  workingHours       LabWorkingHours[]
}

// A lab's opening hours — deliberately simpler than DoctorAvailability:
// no slot length, no slot generation. Labs don't need discrete bookable
// time slots the way teleconsults do; this is purely "we're open these
// hours" information, mainly for display.
model LabWorkingHours {
  id            String   @id @default(uuid()) @db.Uuid
  labProviderId String   @db.Uuid
  dayOfWeek     Int      // 0=Sunday .. 6=Saturday
  openTime      String   // "08:00", 24-hour, plain wall-clock
  closeTime     String   // "20:00"
  createdAt     DateTime @default(now())
  labProvider   LabProvider @relation(fields: [labProviderId], references: [id])
}

model LabService {
  id              String  @id @default(uuid()) @db.Uuid
  labProviderId   String  @db.Uuid
  testName        String
  testCode        String?
  basePrice       Decimal
  turnaroundHours Int?    @default(24)
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
  labProvider     LabProvider @relation(fields: [labProviderId], references: [id])
  orderItems      LabOrderItem[]
}

model LabOrder {
  id                    String   @id @default(uuid()) @db.Uuid
  orderRef              String   @unique
  globalPatientId       String?
  hospitalId            String?
  referringDoctorId     String?  @db.Uuid
  referralAppointmentId String?  @db.Uuid
  labProviderId         String   @db.Uuid
  serviceType           LabServiceType
  homeAddress           String?
  scheduledDate         DateTime?
  scheduledTime         String?
  status                LabOrderStatus @default(requested)
  totalCost             Decimal?
  paymentStatus         PaymentStatus @default(unpaid)
  paymentReference      String?
  paymentAmount         Decimal?
  paymentPhone          String?
  resultPayload         Json?
  lastSyncedStatus      LabOrderStatus? // NULL = never synced. Tracks *which status* was
                                        // last fanned out, not just whether it ever was —
                                        // a LabOrder legitimately needs a sync event both when
                                        // requested AND again when completed (that's the whole
                                        // point of lab results reaching the hospital). A plain
                                        // one-time boolean would silently swallow the second
                                        // transition after the first sync fired.
  source                String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  globalPatient         GlobalPatient? @relation(fields: [globalPatientId], references: [globalPatientId])
  hospital              Hospital?      @relation(fields: [hospitalId], references: [hospitalId])
  referringDoctor       Doctor?        @relation(fields: [referringDoctorId], references: [id])
  referralAppointment   Appointment?   @relation(fields: [referralAppointmentId], references: [id])
  labProvider           LabProvider    @relation(fields: [labProviderId], references: [id])
  items                 LabOrderItem[]
  paymentSplits         PaymentSplit[]

  @@index([globalPatientId])
  @@index([labProviderId, status])
}

model LabOrderItem {
  id           String  @id @default(uuid()) @db.Uuid
  labOrderId   String  @db.Uuid
  labServiceId String  @db.Uuid
  priceAtOrder Decimal
  labOrder     LabOrder   @relation(fields: [labOrderId], references: [id])
  labService   LabService @relation(fields: [labServiceId], references: [id])
}

model TelemedicineSession {
  id              String  @id @default(uuid()) @db.Uuid
  sessionRef      String  @unique
  appointmentId   String  @unique @db.Uuid
  doctorId        String? @db.Uuid
  globalPatientId String?
  roomProvider    String  @default("daily.co")
  roomUrl         String?
  status          TelemedicineStatus @default(scheduled)
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime @default(now())
  appointment     Appointment    @relation(fields: [appointmentId], references: [id])
  doctor          Doctor?        @relation(fields: [doctorId], references: [id])
  globalPatient   GlobalPatient? @relation(fields: [globalPatientId], references: [globalPatientId])
}

// Records each split payment transaction: patient pays the full amount via
// Campay, we then disburse the platform fee to MedVAULT and the remainder
// to the doctor (or hospital, if the doctor has no MoMo of their own) —
// two separate Campay transfer calls. Mirrors the HMS's own
// teleconsult_payment_splits table field-for-field.
// Handles payouts for both teleconsults (Appointment) and lab orders
// (LabOrder) — deliberately one model, not two near-identical ones.
// Exactly one of appointmentId/labOrderId is set, enforced at the
// application layer (payment.service.ts / lab-payment.service.ts), not
// here — Prisma doesn't have a clean way to express "exactly one of these
// two is non-null" as a schema-level constraint.
model PaymentSplit {
  id                 String   @id @default(uuid()) @db.Uuid
  appointmentId      String?  @db.Uuid
  labOrderId         String?  @db.Uuid
  totalAmount        Decimal
  platformFeePct     Decimal  @default(10)
  platformAmount     Decimal
  providerAmount     Decimal
  medvaultMomo       String?
  providerMomo       String?
  providerNetwork    String?
  patientPaymentRef  String?
  platformPayoutRef  String?
  providerPayoutRef  String?
  status             PaymentSplitStatus @default(pending)
  createdAt          DateTime @default(now())
  completedAt        DateTime?
  appointment        Appointment? @relation(fields: [appointmentId], references: [id])
  labOrder           LabOrder?    @relation(fields: [labOrderId], references: [id])
}

// Mirrors the HMS's teleconsult_prescriptions table — issued during or
// after a teleconsult, delivered to the patient, and deliberately NOT
// routed through any hospital pharmacy (that's the whole point of a
// teleconsult prescription: the patient fills it wherever is convenient).
model Prescription {
  id              String   @id @default(uuid()) @db.Uuid
  prescriptionRef String   @unique
  appointmentId   String   @db.Uuid
  globalPatientId String?
  doctorId        String   @db.Uuid
  symptoms        String?
  diagnosis       String?
  notes           String?
  items           Json     @default("[]") // [{type, name, dose, frequency, duration, notes}]
                                           // type: 'medication' | 'lab_request' | 'imaging_request'
  status          String   @default("issued") // issued | sent_to_patient | completed
  sentAt          DateTime?
  createdAt       DateTime @default(now())
  appointment     Appointment    @relation(fields: [appointmentId], references: [id])
  doctor          Doctor         @relation(fields: [doctorId], references: [id])
  globalPatient   GlobalPatient? @relation(fields: [globalPatientId], references: [globalPatientId])
}

model Notification {
  id            String  @id @default(uuid()) @db.Uuid
  channel       NotificationChannel
  recipientType String
  recipientRef  String
  templateType  String
  payload       Json
  status        NotificationStatus @default(pending)
  errorMessage  String?
  sentAt        DateTime?
  createdAt     DateTime @default(now())

  @@index([status])
}

model WhatsAppContact {
  id                String   @id @default(uuid()) @db.Uuid
  waPhoneNumber     String   @unique
  globalPatientId   String?
  conversationState Json?
  lastInteractionAt DateTime?
  createdAt         DateTime @default(now())
  globalPatient     GlobalPatient? @relation(fields: [globalPatientId], references: [globalPatientId])
}

model DeviceToken {
  id        String @id @default(uuid()) @db.Uuid
  ownerType String
  ownerRef  String
  platform  String
  pushToken String
  createdAt DateTime @default(now())

  @@unique([ownerType, ownerRef, pushToken])
}

model OtpCode {
  id          String     @id @default(uuid()) @db.Uuid
  phone       String
  code        String
  purpose     OtpPurpose
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime   @default(now())

  @@index([phone, purpose])
}

// Deliberately lightweight — not an attempt at comprehensive error
// tracking (that's what a real observability tool is for), just enough
// for an admin to see "something's been failing in the background"
// without needing server SSH access to check pm2 logs directly.
// Scoped initially to the unattended background pollers, since those are
// exactly the kind of failure an admin has no other way to notice.
model ErrorLog {
  id        String   @id @default(uuid()) @db.Uuid
  source    String   // e.g. 'poller:appointments', 'poller:lab-orders'
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
